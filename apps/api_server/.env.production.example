NODE_ENV=production
PORT=4000
DB_CLIENT=sqlite
DB_PATH=/data/rhythm.db
DB_HOST=rhythm-postgres
DB_PORT=5432
DB_NAME=rhythm
DB_USER=rhythm_user
DB_PASSWORD=replace-with-strong-password
DB_SSL=false
CORS_ALLOWED_ORIGINS=https://app.vcrcapps.com

GOOGLE_AUTH_CLIENT_ID=your-google-auth-client-id
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=https://api.vcrcapps.com/auth/google/callback

PCO_APPLICATION_ID=your-pco-application-id
PCO_SECRET=your-pco-secret
PCO_REDIRECT_URI=https://api.vcrcapps.com/auth/planning-center/callback

TUNNEL_TOKEN=your-cloudflare-tunnel-token
SQLITE_MIGRATION_PATH=/data/rhythm.db
